@page
@model Schulverwaltung.Web.Pages.Zugriff.VerweigertModel
@{ Layout = null; ViewData["Title"] = "Zugriff gesperrt"; }
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <title>Zugriff gesperrt – BfO Schulverwaltung</title>
    <link rel="stylesheet" href="~/css/schulverwaltung.css" />
    <style>
        body { font-family: 'Segoe UI', sans-serif; background:#f3f2f1; display:flex; align-items:center; justify-content:center; min-height:100vh; margin:0; }
        .box { background:#fff; border:1px solid #edebe9; padding:48px 56px; max-width:480px; text-align:center; }
        h1 { font-size:22px; color:#c50f1f; margin:0 0 16px; }
        p { font-size:14px; color:#323130; margin:0 0 24px; }
        .user { font-size:12px; color:#605e5c; margin-bottom:24px; }
        a { color:#00B7C3; text-decoration:none; font-size:13px; }
    </style>
</head>
<body>
    <div class="box">
        <div style="font-size:48px;margin-bottom:16px">&#128274;</div>
        <h1>Zugriff gesperrt</h1>
        <p>Ihr Konto wurde gesperrt. Bitte wenden Sie sich an den Administrator.</p>
        <div class="user">Angemeldet als: <strong>@Model.AdBenutzername</strong></div>
        <a href="javascript:void(0)" onclick="window.location.reload()">Seite neu laden</a>
    </div>
</body>
</html>
