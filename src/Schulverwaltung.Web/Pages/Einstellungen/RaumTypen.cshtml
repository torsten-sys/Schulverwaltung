@page
@model Schulverwaltung.Web.Pages.Einstellungen.RaumTypenModel
@{ ViewData["Title"] = "Raumtypen"; }

<div class="bc-page">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
        <h1 class="bc-page-title" style="margin:0">Raumtypen</h1>
        <div style="display:flex;gap:6px">
            @if (Model.Bearbeiten)
            {
                <button type="submit" form="form-speichern" class="bc-btn bc-btn-primary">&#128190; Speichern</button>
                <a asp-page="/Einstellungen/RaumTypen" class="bc-btn">&#10005; Abbrechen</a>
            }
            else
            {
                <a asp-page="/Einstellungen/RaumTypen" asp-route-bearbeiten="true" class="bc-btn">&#9998; Bearbeiten</a>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Meldung))
    {
        <div class="bc-alert bc-alert-success">@Model.Meldung</div>
    }
    @if (!string.IsNullOrEmpty(Model.Fehler))
    {
        <div class="bc-alert bc-alert-danger">@Model.Fehler</div>
    }

    @if (!Model.Bearbeiten)
    {
        @* ── ANSICHTSMODUS ── *@
        <div class="bc-table-wrap">
            <table class="bc-table" style="width:100%">
                <thead>
                    <tr>
                        <th style="width:120px">Code</th>
                        <th>Bezeichnung</th>
                        <th style="width:90px;text-align:right">Reihenfolge</th>
                        <th style="width:80px;text-align:center">Internat</th>
                        <th style="width:90px;text-align:center">Gesperrt</th>
                        <th style="width:120px;text-align:center">Verwendung</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vm in Model.Typen)
                    {
                        <tr class="@(vm.Typ.Gesperrt ? "bc-row-gesperrt" : "")">
                            <td><span style="font-family:monospace;font-size:12px;background:#f3f2f1;padding:1px 5px;border-radius:2px">@vm.Typ.Code</span></td>
                            <td>@vm.Typ.Bezeichnung</td>
                            <td style="text-align:right;color:#605e5c">@vm.Typ.Reihenfolge</td>
                            <td style="text-align:center">
                                @if (vm.Typ.IstInternat)
                                {
                                    <span style="color:#00B7C3;font-size:13px" title="Internat-Belegungslogik aktiv">&#10004;</span>
                                }
                                else
                                {
                                    <span style="color:#a19f9d">–</span>
                                }
                            </td>
                            <td style="text-align:center">
                                @if (vm.Typ.Gesperrt)
                                {
                                    <span style="color:#c50f1f;font-size:12px;font-weight:600;padding:1px 6px;background:#fde7e9;border-radius:2px">Gesperrt</span>
                                }
                                else
                                {
                                    <span style="color:#a19f9d">–</span>
                                }
                            </td>
                            <td style="text-align:center">
                                @if (vm.IsVerwendet)
                                {
                                    <span style="color:#107C10;font-size:12px;padding:1px 6px;background:#dff6dd;border-radius:2px">&#10003; Aktiv</span>
                                }
                                else
                                {
                                    <span style="color:#a19f9d;font-size:12px">Nicht verwendet</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Typen.Any())
                    {
                        <tr><td colspan="6" style="text-align:center;color:#a19f9d;padding:16px">Keine Raumtypen vorhanden</td></tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        @* ── BEARBEITUNGSMODUS ── *@
        @Html.AntiForgeryToken()
        <form id="form-speichern" method="post" asp-page-handler="Speichern">
            <div class="bc-table-wrap" style="border:2px solid #2E75B6;border-radius:2px">
                <div style="background:#2E75B6;color:#fff;padding:4px 10px;font-size:11px;font-weight:600;letter-spacing:.5px">
                    BEARBEITUNGSMODUS
                </div>
                <table class="bc-table" style="width:100%">
                    <thead>
                        <tr>
                            <th style="width:130px">Code *</th>
                            <th>Bezeichnung *</th>
                            <th style="width:90px;text-align:right">Reihenfolge</th>
                            <th style="width:80px;text-align:center" title="Steuert ob Belegungslogik aktiv ist">Internat</th>
                            <th style="width:80px;text-align:center">Gesperrt</th>
                            <th style="width:110px;text-align:center">Verwendung</th>
                            <th style="width:40px"></th>
                        </tr>
                    </thead>
                    <tbody id="edit-tbody">
                        @for (int i = 0; i < Model.Typen.Count; i++)
                        {
                            var vm = Model.Typen[i];
                            <tr>
                                <input type="hidden" name="Zeilen[@i].RaumTypId" value="@vm.Typ.RaumTypId" />
                                <td>
                                    <input name="Zeilen[@i].Code" value="@vm.Typ.Code"
                                           class="bc-field-ctrl" maxlength="20" required
                                           style="text-transform:uppercase;width:100%"
                                           @(vm.IsVerwendet ? "readonly" : "") />
                                </td>
                                <td>
                                    <input name="Zeilen[@i].Bezeichnung" value="@vm.Typ.Bezeichnung"
                                           class="bc-field-ctrl" maxlength="100" required
                                           style="width:100%"
                                           @(vm.IsVerwendet ? "readonly" : "") />
                                </td>
                                <td>
                                    <input name="Zeilen[@i].Reihenfolge" value="@vm.Typ.Reihenfolge"
                                           type="number" min="0" class="bc-field-ctrl" style="width:100%" />
                                </td>
                                <td style="text-align:center">
                                    <input name="Zeilen[@i].IstInternat" type="checkbox" value="true"
                                           title="Steuert ob Belegungslogik aktiv ist"
                                           @(vm.Typ.IstInternat ? "checked" : "")
                                           @(vm.IsVerwendet ? "disabled" : "") />
                                    @if (vm.IsVerwendet && vm.Typ.IstInternat)
                                    {
                                        <input type="hidden" name="Zeilen[@i].IstInternat" value="true" />
                                    }
                                </td>
                                <td style="text-align:center">
                                    <input name="Zeilen[@i].Gesperrt" type="checkbox" value="true"
                                           @(vm.Typ.Gesperrt ? "checked" : "") />
                                </td>
                                <td style="text-align:center">
                                    @if (vm.IsVerwendet)
                                    {
                                        <span title="Wird verwendet – Code/Bezeichnung/Internat gesperrt" style="cursor:help">&#128274;</span>
                                    }
                                    else
                                    {
                                        <span style="color:#a19f9d;font-size:11px">–</span>
                                    }
                                </td>
                                <td style="text-align:center">
                                    @if (vm.IsVerwendet)
                                    {
                                        <button type="button" class="bc-icon-btn" style="opacity:.35;cursor:not-allowed"
                                                title="Wird verwendet – kann nicht gelöscht werden" disabled>&#128465;</button>
                                    }
                                    else
                                    {
                                        <button type="button" class="bc-icon-btn-danger"
                                                onclick="deleteTyp(@vm.Typ.RaumTypId, '@Html.Raw(vm.Typ.Bezeichnung.Replace("'", "\\'"))')"
                                                title="Löschen">&#128465;</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </form>
        <div style="margin-top:8px">
            <button type="button" class="bc-btn" id="btn-neue-zeile">+ Neue Zeile</button>
        </div>
    }
</div>

@section Scripts {
@if (Model.Bearbeiten)
{
<script>
(function() {
    var rowCount = @Model.Typen.Count;

    document.getElementById('btn-neue-zeile').addEventListener('click', function() {
        var i = rowCount++;
        var tbody = document.getElementById('edit-tbody');
        var tr = document.createElement('tr');
        tr.innerHTML =
            '<input type="hidden" name="Zeilen[' + i + '].RaumTypId" value="0" />' +
            '<td><input name="Zeilen[' + i + '].Code" class="bc-field-ctrl" maxlength="20" required style="text-transform:uppercase;width:100%" placeholder="CODE" /></td>' +
            '<td><input name="Zeilen[' + i + '].Bezeichnung" class="bc-field-ctrl" maxlength="100" required style="width:100%" placeholder="Bezeichnung" /></td>' +
            '<td><input name="Zeilen[' + i + '].Reihenfolge" type="number" min="0" value="0" class="bc-field-ctrl" style="width:100%" /></td>' +
            '<td style="text-align:center"><input name="Zeilen[' + i + '].IstInternat" type="checkbox" value="true" title="Steuert ob Belegungslogik aktiv ist" /></td>' +
            '<td style="text-align:center"><input name="Zeilen[' + i + '].Gesperrt" type="checkbox" value="true" /></td>' +
            '<td></td>' +
            '<td style="text-align:center"><button type="button" class="bc-icon-btn-danger" onclick="removeRow(this)" title="Zeile entfernen">&#128465;</button></td>';
        tbody.appendChild(tr);
        tr.querySelector('input[type=text],input:not([type])').focus();
    });

    window.removeRow = function(btn) {
        btn.closest('tr').remove();
        rowCount--;
    };

    window.deleteTyp = function(raumTypId, bezeichnung) {
        if (!confirm("'" + bezeichnung + "' wirklich löschen?")) return;
        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        var f = document.createElement('form');
        f.method = 'post';
        f.action = window.location.pathname + '?handler=Loeschen&bearbeiten=true';
        var h1 = document.createElement('input'); h1.type = 'hidden'; h1.name = 'raumTypId'; h1.value = raumTypId;
        var h2 = document.createElement('input'); h2.type = 'hidden'; h2.name = '__RequestVerificationToken'; h2.value = token;
        f.appendChild(h1); f.appendChild(h2);
        document.body.appendChild(f);
        f.submit();
    };
})();
</script>
}
}
