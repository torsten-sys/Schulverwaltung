@page
@model Schulverwaltung.Web.Pages.Lehrgaenge.MeisterAuswertungModel
@{ ViewData["Title"] = "Meisterkurs Auswertungen"; }

<div class="bc-page">
    <div class="bc-card-topbar">
        <div class="bc-card-topbar-left">
            <a href="/Lehrgaenge/Karte/@Model.Id" class="bc-back-btn">&#x2190;</a>
            <span class="bc-page-badge">Auswertungen | @Model.LehrgangNr</span>
        </div>
    </div>

    <h1 class="bc-card-title">
        <span class="bc-title-nr">@Model.LehrgangNr</span>
        <span class="bc-title-sep"> · </span>
        <span>Meisterkurs Auswertungen</span>
    </h1>

    @* ── Abschnitt: Patientenhistorie ──────────────────────────────────── *@
    <p class="bc-section-title" style="margin-top:16px">PATIENTENHISTORIE</p>

    <div class="bc-action-bar" style="margin-bottom:8px">
        <form method="get" style="display:contents">
            <input type="hidden" name="id" value="@Model.Id" />
            <input name="FilterPerson" class="bc-search" placeholder="Nach Patient oder Meisterschüler filtern..."
                   value="@Model.FilterPerson" style="width:300px" autocomplete="off" />
            <button type="submit" class="bc-btn">Filtern</button>
            @if (!string.IsNullOrEmpty(Model.FilterPerson))
            {
                <a href="/Lehrgaenge/MeisterAuswertung?id=@Model.Id" class="bc-btn">✕ Filter zurücksetzen</a>
            }
        </form>
    </div>

    @if (Model.PatientenHistorie.Any())
    {
        var pvAbschnitte = Model.PatientenHistorie.First().Teilnahmen;
        <div style="overflow-x:auto">
            <table class="bc-table" style="width:100%;font-size:12px">
                <thead>
                    <tr>
                        <th style="min-width:150px">Patient</th>
                        @foreach (var t in pvAbschnitte)
                        {
                            <th style="min-width:100px;text-align:center">@t.Nummer. @t.AbschnittBez</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.PatientenHistorie)
                    {
                        <tr>
                            <td>@p.PatientName<br /><small style="color:#605e5c">@p.PersonNr</small></td>
                            @foreach (var t in p.Teilnahmen)
                            {
                                <td style="text-align:center">
                                    @if (t.Teilgenommen)
                                    {
                                        var bStyle = t.BuchungsStatus switch {
                                            2 => "color:#107C10;font-weight:600",
                                            1 => "color:#0078D4",
                                            _ => "color:#605e5c"
                                        };
                                        <span style="@bStyle" title="MS1: @(t.MS1 ?? "–") / MS2: @(t.MS2 ?? "–")">✓</span>
                                    }
                                    else { <span style="color:#e1dfdd">–</span> }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p style="color:#a19f9d;padding:12px">Keine Patientendaten vorhanden.</p>
    }

    @* ── Abschnitt: Meisterschüler-Übersicht ──────────────────────────── *@
    <p class="bc-section-title" style="margin-top:24px">MEISTERSCHÜLER-ÜBERSICHT</p>

    @if (Model.SchuelerUebersicht.Any())
    {
        <table class="bc-table" style="width:100%">
            <thead>
                <tr>
                    <th>Meisterschüler</th>
                    <th class="col-num">Versorgungen</th>
                    <th class="col-num">Als MS1</th>
                    <th class="col-num">Als MS2</th>
                    <th class="col-num">HM übergeben</th>
                    <th class="col-num">Gesamtnote</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.SchuelerUebersicht)
                {
                    var noteColor = s.Gesamtnote switch {
                        <= 2.5m => "#107C10",
                        <= 4.5m => "#8a6914",
                        _ when s.Gesamtnote.HasValue => "#c50f1f",
                        _ => "#a19f9d"
                    };
                    <tr>
                        <td>
                            <a href="/Personen/Karte/@s.PersonId" style="color:#00B7C3">@s.PersonName</a>
                            <small style="color:#605e5c"> @s.PersonNr</small>
                        </td>
                        <td class="col-num">@s.Versorgungen</td>
                        <td class="col-num">@s.AlsMS1</td>
                        <td class="col-num">@s.AlsMS2</td>
                        <td class="col-num">@s.HilfsmittelUebergeben</td>
                        <td class="col-num" style="font-weight:600;color:@noteColor">
                            @(s.Gesamtnote?.ToString("0.0") ?? "–")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p style="color:#a19f9d;padding:12px">Keine Teilnehmer vorhanden.</p>
    }

    @* ── Abschnitt: Notenverteilung ────────────────────────────────────── *@
    <p class="bc-section-title" style="margin-top:24px">NOTENVERTEILUNG PER FACH</p>

    @if (Model.Notenverteilung.Any())
    {
        <table class="bc-table" style="width:100%">
            <thead>
                <tr>
                    <th>Fach</th>
                    <th class="col-num">Gewichtung</th>
                    <th class="col-num">Ø Note</th>
                    <th class="col-num">Beste</th>
                    <th class="col-num">Schlechteste</th>
                    <th class="col-num">Noch offen</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var n in Model.Notenverteilung)
                {
                    <tr>
                        <td>@n.Fach</td>
                        <td class="col-num" style="color:#605e5c">@n.Gewichtung.ToString("0.00")</td>
                        <td class="col-num" style="font-weight:@(n.DurchschnittNote.HasValue ? "600" : "400");color:@(n.DurchschnittNote.HasValue ? "#1F3864" : "#a19f9d")">
                            @(n.DurchschnittNote?.ToString("0.0") ?? "–")
                        </td>
                        <td class="col-num" style="color:#107C10;font-weight:@(n.BesteNote.HasValue ? "600" : "400")">
                            @(n.BesteNote?.ToString() ?? "–")
                        </td>
                        <td class="col-num" style="color:@(n.SchlechtsteNote >= 5 ? "#c50f1f" : "inherit")">
                            @(n.SchlechtsteNote?.ToString() ?? "–")
                        </td>
                        <td class="col-num">
                            @if (n.NochOffen > 0)
                            {
                                <span style="color:#D83B01;font-weight:600">@n.NochOffen</span>
                            }
                            else { <span style="color:#107C10">✓</span> }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p style="color:#a19f9d;padding:12px">Noch keine Noten vorhanden.</p>
    }
</div>
