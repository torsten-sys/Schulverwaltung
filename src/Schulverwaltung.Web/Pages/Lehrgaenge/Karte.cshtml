@page "{id:int?}"
@model Schulverwaltung.Web.Pages.Lehrgaenge.KarteModel
@using Schulverwaltung.Domain.Enums
@using System.Globalization
@{ ViewData["Title"] = Model.Titel; var de = new CultureInfo("de-DE"); }

@functions {
    static string StatusClass(string text) => text switch {
        "Planung"         => "bc-badge-planung",
        "Anmeldung offen" => "bc-badge-offen",
        "Aktiv"           => "bc-badge-aktiv",
        "Abgeschlossen"   => "bc-badge-abgeschlossen",
        "Storniert"       => "bc-badge-storniert",
        _                 => "bc-badge-planung"
    };
    static string LgStatusText(byte s) => s switch {
        0 => "Planung", 1 => "Anmeldung offen", 2 => "Aktiv",
        3 => "Abgeschlossen", 4 => "Storniert", _ => ""
    };
    static string TypStyle(byte typ) => typ switch {
        0 => "background:#1F3864;color:#fff",
        1 => "background:#8764B8;color:#fff",
        2 => "background:#107C10;color:#fff",
        3 => "background:#D83B01;color:#fff",
        4 => "background:#00B7C3;color:#fff",
        _ => "background:#605e5c;color:#fff"
    };
    static string TypText(byte typ) => typ switch {
        0 => "MEISTERVORBEREITUNG", 1 => "PODOLOGIE",
        2 => "ÜB. AUSBILDUNG", 3 => "SONDERLEHRGANG OST",
        4 => "SONDERLEHRGANG PODO.", _ => ""
    };
    static string RolleClass(LehrgangPersonRolle r) => r switch {
        LehrgangPersonRolle.Teilnehmer => "bc-badge-rolle-teilnehmer",
        LehrgangPersonRolle.Dozent     => "bc-badge-rolle-dozent",
        LehrgangPersonRolle.Assistent  => "bc-badge-rolle-pruefer",
        _                              => "bc-badge-planung"
    };
    static string PersonStatusClass(string s) => s switch {
        "Warteliste" => "bc-badge-warteliste",
        "Angemeldet" => "bc-badge-angemeldet",
        "Abgemeldet" => "bc-badge-abgemeldet",
        "Bestanden"  => "bc-badge-bestanden",
        _            => "bc-badge-planung"
    };
    static string EinheitTypText(byte t) => t switch {
        0 => "Unterricht", 1 => "Prüfung", 2 => "Pause", 3 => "Exkursion", _ => ""
    };
    static string EinheitTypStyle(byte t) => t switch {
        0 => "background:#cce4ff;color:#0078D4",
        1 => "background:#fff4ce;color:#8a6914",
        2 => "background:#f3f2f1;color:#605e5c",
        3 => "background:#dff6dd;color:#107C10",
        _ => "background:#f3f2f1;color:#605e5c"
    };
    static string EreignisStyle(string e) => e switch {
        "LehrgangAngelegt"    => "background:#dff6dd;color:#107C10",
        "StammdatenGeaendert" => "background:#cce4ff;color:#0078D4",
        "StatusGeaendert"     => "background:#fff4ce;color:#8a6914",
        "PersonHinzugefuegt"  => "background:#dff6dd;color:#107C10",
        "PersonEntfernt"      => "background:#fde7e9;color:#c50f1f",
        "EinheitHinzugefuegt" => "background:#dff6dd;color:#107C10",
        "EinheitGeaendert"    => "background:#cce4ff;color:#0078D4",
        _                     => "background:#f3f2f1;color:#323130"
    };
}

<div class="bc-page" style="max-width:none">

    @if (!ModelState.IsValid)
    {
        <div class="bc-alert">
            @foreach (var e in ModelState.Values.SelectMany(v => v.Errors))
            { <div>@e.ErrorMessage</div> }
        </div>
    }

    @* Topbar *@
    <div class="bc-card-topbar">
        <div class="bc-card-topbar-left">
            <a href="/Lehrgaenge" class="bc-back-btn" title="Zurück zu Lehrgänge">&#x2190;</a>
            <span class="bc-page-badge">Lehrgangs-Karte | Arbeitsdatum: @DateTime.Today.ToString("dd.MM.yyyy")</span>
        </div>
        <div class="bc-card-topbar-right">
            <button type="submit" form="form-speichern" class="bc-icon-btn" title="Speichern">&#x2714;</button>
            @if (!Model.IstNeu)
            {
                <a href="/Lehrgaenge/Karte" class="bc-icon-btn" title="Neuer Lehrgang">+</a>
                @if (Model.Form.Status == 0)
                {
                    <form method="post" asp-page-handler="Loeschen"
                          onsubmit="return confirm('Lehrgang wirklich löschen?')" style="display:contents">
                        <input type="hidden" name="id" value="@Model.Form.LehrgangId" />
                        <button type="submit" class="bc-icon-btn bc-icon-btn-danger" title="Löschen">&#x1F5D1;</button>
                    </form>
                }
            }
        </div>
    </div>

    @* Title *@
    <h1 class="bc-card-title">
        @if (Model.IstNeu)
        {
            <span>Neuer Lehrgang</span>
        }
        else
        {
            <span class="bc-title-nr">@Model.Form.LehrgangNr</span>
            <span class="bc-title-sep"> · </span>
            <span>@Model.Form.Bezeichnung</span>
            <span style="margin-left:8px;padding:2px 10px;font-size:11px;border-radius:2px;font-weight:600;
                         @TypStyle(Model.Form.LehrgangTyp)">
                @TypText(Model.Form.LehrgangTyp)
            </span>
            <span class="bc-title-status">
                <span class="bc-badge @StatusClass(LgStatusText(Model.Form.Status))">@LgStatusText(Model.Form.Status)</span>
            </span>
        }
    </h1>

    @* Modal-Button-Leiste (nur Meisterkurs, wenn gespeichert) *@
    @if (Model.ZeigeMeisterTabs && !Model.IstNeu)
    {
        <div class="bc-meister-btn-strip">
            <button type="button" class="bc-meister-btn"
                    onclick="location.href='/Lehrgaenge/Kursmodule?id=@Model.Form.LehrgangId'">
                <span class="bc-meister-btn-icon">&#9781;</span> Kursmodule
            </button>
            <button type="button" class="bc-meister-btn"
                    onclick="location.href='/Lehrgaenge/FaecherNoten?id=@Model.Form.LehrgangId'">
                <span class="bc-meister-btn-icon">&#10003;</span> Fächer &amp; Noten
            </button>
            <button type="button" class="bc-meister-btn"
                    onclick="location.href='/Lehrgaenge/MeisterFunktionen?id=@Model.Form.LehrgangId'">
                <span class="bc-meister-btn-icon">&#9673;</span> Funktionen
            </button>
            <button type="button" class="bc-meister-btn"
                    onclick="location.href='/Lehrgaenge/MeisterInternat?id=@Model.Form.LehrgangId'">
                <span class="bc-meister-btn-icon">&#9634;</span> Internat
            </button>
            <button type="button" class="bc-meister-btn"
                    onclick="location.href='/Lehrgaenge/Aenderungsprotokoll?id=@Model.Form.LehrgangId'">
                <span class="bc-meister-btn-icon">&#9776;</span> Änderungsprotokoll
            </button>
            <button type="button" class="bc-meister-btn"
                    onclick="location.href='/Lehrgaenge/MeisterEinladungen?id=@Model.Form.LehrgangId'">
                <span class="bc-meister-btn-icon">&#9993;</span> Einladungen
            </button>
            <div class="bc-meister-dd" id="dok-dd-wrap">
                <button type="button" class="bc-meister-btn" onclick="toggleDokDropdown()">
                    <span class="bc-meister-btn-icon">&#9654;</span> Dokumente &#9660;
                </button>
                <div class="bc-meister-dd-menu" id="dok-dd-menu">
                    <a class="bc-meister-dd-item"
                       onclick="location.href='/Berichte/Vorschau?key=lehrgang-teilnehmerliste&id=@Model.Form.LehrgangId';closeDokDropdown()">
                        Teilnehmerliste
                    </a>
                </div>
            </div>
        </div>
    }

    @* Action Tabs – nur für Nicht-Meisterkurs (oder neuer Lehrgang) *@
    @if (!Model.ZeigeMeisterTabs || Model.IstNeu)
    {
    <nav class="bc-action-tabs">
        <a href="#" class="bc-action-tab active" data-panel="panel-allgemein">Allgemein</a>
        @if (!Model.IstNeu)
        {
            <a href="#" class="bc-action-tab" data-panel="panel-personen">Personen (@Model.ZugeordnetePersonen.Count)</a>
            @if (Model.ZeigeEinheiten)
            {
                <a href="#" class="bc-action-tab" data-panel="panel-einheiten">Einheiten (@Model.Einheiten.Count)</a>
            }
            <a href="#" class="bc-action-tab" data-panel="panel-protokoll">Änderungsprotokoll (@Model.Aenderungsposten.Count)</a>
            <a href="#" class="bc-action-tab" data-panel="panel-aktionen">Aktionen</a>
        }
    </nav>
    }

    @* 75/25 Layout *@
    <div style="display:flex;gap:16px;align-items:flex-start">

        @* ── LINKE SEITE ────────────────────────────────────────────────────── *@
        <div style="flex:3;min-width:0">

        @if (Model.ZeigeMeisterTabs && !Model.IstNeu)
        {
            @* ════════════════════════════════════════════════════════════════
               MEISTERKURS-LAYOUT: 4 vertikale Sektionen
               ════════════════════════════════════════════════════════════════ *@
            <form id="form-speichern" method="post" asp-page-handler="Speichern">
                <input type="hidden" asp-for="Form.LehrgangId" />
                <input type="hidden" asp-for="Form.LehrgangTyp" />

                @* ── 1. Allgemein ─────────────────────────────────────────── *@
                <div class="bc-meister-section">
                    <p class="bc-section-title">1. Allgemein</p>
                    <div class="bc-fields-2col">
                        <div class="bc-field">
                            <span class="bc-field-label">Nr.</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-md">
                                <input class="bc-field-ctrl" value="@Model.Form.LehrgangNr" readonly />
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label">Typ</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-lg">
                                <input class="bc-field-ctrl" value="@TypText(Model.Form.LehrgangTyp)" readonly />
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label req">Bezeichnung</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-lg">
                                <input asp-for="Form.Bezeichnung" class="bc-field-ctrl" />
                                <span asp-validation-for="Form.Bezeichnung" class="bc-field-err"></span>
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label">Langbezeichnung</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-lg">
                                <input asp-for="Form.BezeichnungLang" class="bc-field-ctrl" />
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label req">Startdatum</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-md">
                                <input asp-for="Form.StartDatum" class="bc-field-ctrl" type="date" />
                                <span asp-validation-for="Form.StartDatum" class="bc-field-err"></span>
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label">Enddatum</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-md">
                                <input asp-for="Form.EndDatum" class="bc-field-ctrl" type="date" />
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label">Min. Teilnehmer</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-sm">
                                <input asp-for="Form.MinTeilnehmer" class="bc-field-ctrl" type="number" min="0" />
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label">Max. Teilnehmer</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-sm">
                                <input asp-for="Form.MaxTeilnehmer" class="bc-field-ctrl" type="number" min="0" />
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label">Lehrgangsart</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-md">
                                <select asp-for="Form.ArtId" class="bc-field-ctrl">
                                    <option value="">– keine –</option>
                                    @foreach (var art in Model.LehrgangArten)
                                    {
                                        <option value="@art.ArtId">@art.Bezeichnung</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label">Status</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-md">
                                <input class="bc-field-ctrl" value="@LgStatusText(Model.Form.Status)" readonly />
                            </div>
                        </div>
                    </div>
                </div>

                @* ── 3. Kosten ────────────────────────────────────────────── *@
                <div class="bc-meister-section">
                    <p class="bc-section-title">3. Kosten</p>
                    <div class="bc-fields-2col">
                        <div class="bc-field">
                            <span class="bc-field-label">Lehrgangskosten</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-md">
                                <input asp-for="Form.KostenLehrgang" class="bc-field-ctrl" type="number"
                                       step="0.01" min="0" />
                            </div>
                        </div>
                        <div></div>
                        <div class="bc-field">
                            <span class="bc-field-label">Internat Doppelzimmer</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-md">
                                <input asp-for="Form.KostenInternatDZ" class="bc-field-ctrl" type="number"
                                       step="0.01" min="0" />
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label">Internat Einzelzimmer</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-md">
                                <input asp-for="Form.KostenInternatEZ" class="bc-field-ctrl" type="number"
                                       step="0.01" min="0" />
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label">Höhe Grundzahlung</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-md">
                                <input asp-for="Form.GrundzahlungBetrag" class="bc-field-ctrl" type="number"
                                       step="0.01" min="0" />
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label">Termin Grundzahlung</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-md">
                                <input asp-for="Form.GrundzahlungTermin" class="bc-field-ctrl" type="date" />
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label">Beginn Abbuchung</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-md">
                                <input asp-for="Form.BeginnAbbuchung" class="bc-field-ctrl" type="date" />
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label">Anzahl Raten</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-sm">
                                <input asp-for="Form.AnzahlRaten" class="bc-field-ctrl" type="number" min="1" max="60"
                                       placeholder="6" />
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label">Kaution Werkstatt</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-md">
                                <input asp-for="Form.KautionWerkstatt" class="bc-field-ctrl" type="number"
                                       step="0.01" min="0" />
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label">Kaution Internat</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-md">
                                <input asp-for="Form.KautionInternat" class="bc-field-ctrl" type="number"
                                       step="0.01" min="0" />
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label">Verwaltungspauschale</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-md">
                                <input asp-for="Form.Verwaltungspauschale" class="bc-field-ctrl" type="number"
                                       step="0.01" min="0" />
                            </div>
                        </div>
                    </div>
                </div>
            </form>

            @* ── 2. Teilnehmer ────────────────────────────────────────────── *@
            <div class="bc-meister-section">
                <p class="bc-section-title">2. Teilnehmer</p>
                @{
                    var meisterTeilnehmer = Model.ZugeordnetePersonen
                        .Where(p => p.Rolle == LehrgangPersonRolle.Teilnehmer)
                        .ToList();
                }

                @* Teilnehmer hinzufügen *@
                <form method="post" asp-page-handler="PersonHinzufuegen"
                      style="display:flex;gap:6px;align-items:center;margin-bottom:10px;flex-wrap:wrap">
                    <input type="hidden" name="id" value="@Model.Form.LehrgangId" />
                    <input type="hidden" name="rolle" value="0" />
                    <select name="personId" id="mk-sel-person" class="bc-field-ctrl" style="width:280px">
                        <option value="">– Teilnehmer wählen –</option>
                        @foreach (var item in Model.PersonenAuswahl.Items.Where(i => i.RolleTyp == 0))
                        {
                            <option value="@item.PersonId">@item.Text</option>
                        }
                    </select>
                    <button type="submit" class="bc-btn bc-btn-primary">+ Hinzufügen</button>
                </form>

                <table class="bc-table" style="width:100%">
                    <thead>
                        <tr>
                            <th>Nr.</th><th>Name</th><th>Status</th>
                            <th>Betrieb</th><th class="col-date">Angemeldet</th>
                            <th style="width:36px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in meisterTeilnehmer)
                        {
                            <tr style="cursor:pointer"
                                onclick="openModal('/Personen/Karte/@p.PersonId')">
                                <td>@p.PersonNr</td>
                                <td>@p.Nachname, @p.Vorname</td>
                                <td><span class="bc-badge @PersonStatusClass(p.StatusText)">@p.StatusText</span></td>
                                <td style="font-size:12px;color:#605e5c">@(p.BetriebName ?? "–")</td>
                                <td class="col-date">@p.AnmeldungsDatum.ToString("dd.MM.yyyy")</td>
                                <td onclick="event.stopPropagation()">
                                    <form method="post" asp-page-handler="PersonEntfernen"
                                          onsubmit="return confirm('Teilnehmer entfernen?')">
                                        <input type="hidden" name="id" value="@Model.Form.LehrgangId" />
                                        <input type="hidden" name="personId" value="@p.PersonId" />
                                        <input type="hidden" name="rolle" value="0" />
                                        <button class="bc-btn-remove">&#x2715;</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (!meisterTeilnehmer.Any())
                        {
                            <tr><td colspan="6" style="text-align:center;color:#a19f9d;padding:12px">
                                Noch keine Teilnehmer zugeordnet
                            </td></tr>
                        }
                    </tbody>
                </table>
            </div>

            @* ── 4. Aktionen ──────────────────────────────────────────────── *@
            <div class="bc-meister-section">
                <p class="bc-section-title">4. Aktionen</p>
                <div class="bc-actions-section">
                    <h6>Status ändern</h6>
                    <form method="post" asp-page-handler="Status"
                          asp-route-id="@Model.Form.LehrgangId" class="bc-actions-row">
                        @{ var mkSelStat = Model.Form.Status; }
                        <select name="neuerStatus" class="bc-field-ctrl" style="width:200px">
                            @if (mkSelStat == 0) { <option value="0" selected>Planung</option> } else { <option value="0">Planung</option> }
                            @if (mkSelStat == 1) { <option value="1" selected>Anmeldung offen</option> } else { <option value="1">Anmeldung offen</option> }
                            @if (mkSelStat == 2) { <option value="2" selected>Aktiv</option> } else { <option value="2">Aktiv</option> }
                            @if (mkSelStat == 3) { <option value="3" selected>Abgeschlossen</option> } else { <option value="3">Abgeschlossen</option> }
                        </select>
                        <button type="submit" class="bc-btn bc-btn-primary">Übernehmen</button>
                    </form>
                </div>
                @if (Model.Form.Status == 0 || Model.Form.Status == 1)
                {
                    <div class="bc-actions-section">
                        <h6>Lehrgang absagen</h6>
                        <div class="bc-actions-row">
                            <form method="post" asp-page-handler="Absagen"
                                  onsubmit="return confirm('Lehrgang wirklich absagen?')">
                                <input type="hidden" name="id" value="@Model.Form.LehrgangId" />
                                <button type="submit" class="bc-btn bc-btn-danger">Absagen (→ Storniert)</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            @* ════════════════════════════════════════════════════════════════
               STANDARD-LAYOUT: Tab-Panels (alle anderen Typen + neuer Lehrgang)
               ════════════════════════════════════════════════════════════════ *@

            @* Panel: Allgemein *@
            <div id="panel-allgemein" class="bc-tab-panel active">
                <form id="form-speichern" method="post" asp-page-handler="Speichern">
                    <input type="hidden" asp-for="Form.LehrgangId" />
                    @if (!Model.IstNeu) { <input type="hidden" asp-for="Form.LehrgangTyp" /> }

                    <p class="bc-section-title">Stammdaten</p>
                    <div class="bc-fields-2col">
                        @* Linke Spalte *@
                        @if (!Model.IstNeu)
                        {
                            <div class="bc-field">
                                <span class="bc-field-label">Nr.</span>
                                <span class="bc-field-dots"></span>
                                <div class="bc-field-right bc-field-right-md">
                                    <input class="bc-field-ctrl" value="@Model.Form.LehrgangNr" readonly />
                                </div>
                            </div>
                        }
                        <div class="bc-field">
                            <span class="bc-field-label">Typ</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-lg">
                                @if (Model.IstNeu)
                                {
                                    <select asp-for="Form.LehrgangTyp" class="bc-field-ctrl">
                                        <option value="0">Meistervorbereitung</option>
                                        <option value="1">Podologie</option>
                                        <option value="2">Üb. Ausbildung</option>
                                        <option value="3">Sonderlehrgang OST</option>
                                        <option value="4">Sonderlehrgang Podologie</option>
                                    </select>
                                }
                                else
                                {
                                    <input class="bc-field-ctrl" value="@TypText(Model.Form.LehrgangTyp)" readonly />
                                }
                            </div>
                        </div>
                        <div class="bc-field">
                            <span class="bc-field-label req">Bezeichnung</span>
                            <span class="bc-field-dots"></span>
                            <div class="bc-field-right bc-field-right-lg">
                                <input asp-for="Form.Bezeichnung" class="bc-field-ctrl" />
                                <span asp-validation-for="Form.Bezeichnung" class="bc-field-err"></span>
                            </div>
                        </div>
                        <div class="bc-field">
