@page
@model Schulverwaltung.Web.Pages.Lehrgaenge.MeisterNotenTeilnehmerModel
@{ ViewData["Title"] = "Noten · " + Model.PersonName; }

<div class="bc-page">
    <div class="bc-card-topbar">
        <div class="bc-card-topbar-left">
            <a href="/Lehrgaenge/Karte?id=@Model.LehrgangId" class="bc-back-btn" title="Zurück">&#8592;</a>
            <span class="bc-page-badge">NOTEN</span>
        </div>
        <div style="display:flex;gap:6px">
            <button type="submit" form="form-noten" class="bc-btn bc-btn-primary">Speichern</button>
            <a href="/Lehrgaenge/Karte?id=@Model.LehrgangId" class="bc-btn">Abbrechen</a>
            <button type="button" class="bc-btn" disabled="@(!Model.AlleBenotet)" title="Nur aktiv wenn alle Noten eingetragen">
                Zeugnis erstellen
            </button>
        </div>
    </div>

    <h1 class="bc-card-title">
        <span class="bc-title-nr">@(Model.Lehrgang?.LehrgangNr ?? "")</span>
        <span class="bc-title-sep">·</span>
        <span>@(Model.Lehrgang?.Bezeichnung ?? "") › Noten · @Model.PersonName</span>
    </h1>

    @if (!string.IsNullOrEmpty(Model.Fehler))
    {
        <div class="bc-alert">@Model.Fehler</div>
    }

    @* Navigation zwischen Teilnehmern *@
    <div style="display:flex;align-items:center;gap:12px;margin:8px 0 16px 0;font-size:13px">
        @if (Model.VorherigePersonId > 0)
        {
            <a href="?lehrgangId=@Model.LehrgangId&personId=@Model.VorherigePersonId" class="bc-btn bc-btn-sm">← Vorheriger</a>
        }
        else
        {
            <span class="bc-btn bc-btn-sm" style="opacity:0.4;pointer-events:none">← Vorheriger</span>
        }
        <span style="color:#605e5c">@Model.TeilnehmerNr von @Model.TeilnehmerGesamt</span>
        @if (Model.NaechstePersonId > 0)
        {
            <a href="?lehrgangId=@Model.LehrgangId&personId=@Model.NaechstePersonId" class="bc-btn bc-btn-sm">Nächster →</a>
        }
        else
        {
            <span class="bc-btn bc-btn-sm" style="opacity:0.4;pointer-events:none">Nächster →</span>
        }
    </div>

    <form id="form-noten" method="post" asp-page-handler="Speichern">
        <input type="hidden" name="lehrgangId" value="@Model.LehrgangId" />
        <input type="hidden" name="personId"   value="@Model.PersonId" />

        <div style="overflow-x:auto">
            <table class="bc-table" style="width:90%;font-size:12px">
                <thead>
                    <tr>
                        <th>Fach</th>
                        <th style="width:80px;text-align:right">Gewichtung</th>
                        <th style="width:90px;text-align:center">Note</th>
                        <th style="width:200px">Dozent</th>
                        <th style="width:110px">Datum</th>
                        <th>Notiz</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.FachNoten.Count; i++)
                    {
                        var fn = Model.FachNoten[i];
                        var noteStyle = fn.Note switch {
                            1 or 2 => "background:#dff6dd;color:#107C10",
                            3 or 4 => "background:#fff4ce;color:#8a6914",
                            5 or 6 => "background:#fde7e9;color:#c50f1f",
                            _      => "background:#f3f2f1;color:#a19f9d"
                        };
                        <tr>
                            <td>
                                <input type="hidden" name="noteIds"   value="@fn.NoteId" />
                                <input type="hidden" name="fachIds"   value="@fn.FachId" />
                                @fn.Bezeichnung
                            </td>
                            <td style="text-align:right;color:#605e5c">@fn.Gewichtung.ToString("0.00")</td>
                            <td style="text-align:center;padding:2px">
                                <select name="noten" class="bc-field-ctrl noten-select"
                                        style="@noteStyle;width:70px;text-align:center;font-weight:600"
                                        data-gewichtung="@fn.Gewichtung.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)">
                                    <option value="">–</option>
                                    @if (fn.Note == 1) { <option value="1" selected>1</option> } else { <option value="1">1</option> }
                                    @if (fn.Note == 2) { <option value="2" selected>2</option> } else { <option value="2">2</option> }
                                    @if (fn.Note == 3) { <option value="3" selected>3</option> } else { <option value="3">3</option> }
                                    @if (fn.Note == 4) { <option value="4" selected>4</option> } else { <option value="4">4</option> }
                                    @if (fn.Note == 5) { <option value="5" selected>5</option> } else { <option value="5">5</option> }
                                    @if (fn.Note == 6) { <option value="6" selected>6</option> } else { <option value="6">6</option> }
                                </select>
                            </td>
                            <td>
                                <select name="dozentPersonIds" class="bc-field-ctrl" style="width:100%;font-size:11px">
                                    <option value="">– kein –</option>
                                    @foreach (var d in Model.DozentenListe)
                                    {
                                        @if (fn.DozentPersonId == d.PersonId)
                                        {
                                            <option value="@d.PersonId" selected>@d.AnzeigeName</option>
                                        }
                                        else
                                        {
                                            <option value="@d.PersonId">@d.AnzeigeName</option>
                                        }
                                    }
                                </select>
                            </td>
                            <td>
                                <input name="bewertungsDaten" type="date" class="bc-field-ctrl"
                                       value="@(fn.BewertungsDatum?.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd"))" />
                            </td>
                            <td>
                                <input name="notizen" class="bc-field-ctrl" style="width:100%"
                                       value="@(fn.Notiz ?? "")" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div style="margin-top:12px;padding:8px 12px;background:#f9f8f7;border:1px solid #e1dfdd;font-size:13px;display:inline-block">
            Gesamtnote (gew. Durchschnitt): <strong id="gesamtnote-anzeige">@(Model.Gesamtnote?.ToString("0.0") ?? "–")</strong>
            &nbsp;&nbsp;|&nbsp;&nbsp;
            Benotete Fächer: <strong>@Model.BenoteteFaecher von @Model.GesamtFaecher</strong>
        </div>
    </form>
</div>

@section Scripts {
<script>
(function() {
    // Noten-Farbe live
    document.querySelectorAll('.noten-select').forEach(function(sel) {
        sel.addEventListener('change', function() { aktualisiereNoteStyle(this); });
        aktualisiereNoteStyle(sel);
    });

    function aktualisiereNoteStyle(sel) {
        var v = parseInt(sel.value);
        if (v === 1 || v === 2)      sel.style.cssText += ';background:#dff6dd;color:#107C10';
        else if (v === 3 || v === 4) sel.style.cssText += ';background:#fff4ce;color:#8a6914';
        else if (v === 5 || v === 6) sel.style.cssText += ';background:#fde7e9;color:#c50f1f';
        else                          sel.style.cssText += ';background:#f3f2f1;color:#a19f9d';
        aktualisiereGesamtnote();
    }

    function aktualisiereGesamtnote() {
        var selects = document.querySelectorAll('.noten-select');
        var sumGew = 0, sumNoten = 0, gesamt = selects.length, benotet = 0;
        selects.forEach(function(s) {
            var gew  = parseFloat(s.dataset.gewichtung) || 1;
            var note = parseInt(s.value);
            sumGew += gew;
            if (!isNaN(note) && note >= 1 && note <= 6) {
                sumNoten += note * gew;
                benotet++;
            }
        });
        var el = document.getElementById('gesamtnote-anzeige');
        if (benotet === gesamt && gesamt > 0 && sumGew > 0) {
            el.textContent = (sumNoten / sumGew).toFixed(1).replace('.', ',');
        } else {
            el.textContent = '–';
        }
    }
})();
</script>
}
