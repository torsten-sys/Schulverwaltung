@page
@model Schulverwaltung.Web.Pages.Betriebe.IndexModel
@{ ViewData["Title"] = "Betriebe"; }

<div class="bc-page">
    <h1 class="bc-page-title">Betriebe</h1>

    <div class="bc-action-bar">
        @if (Model.DarfBearbeiten)
        {
            <button class="bc-btn bc-btn-primary" onclick="openModal('/Betriebe/Karte')">+ Neu</button>
            <span class="bc-sep"></span>
            <button id="btn-bearbeiten" class="bc-btn disabled" onclick="openModalWithNav(this.dataset.url)" data-url="#">✎ Bearbeiten</button>
        }
        <input type="search" id="bc-search" class="bc-search" placeholder="Suchen..." autocomplete="off" />
        <span class="bc-entry-count" id="entry-count"></span>
    </div>

    <div class="bc-list-layout">
        <div class="bc-list-main">
            <div class="bc-table-wrap">
                <table class="bc-table" id="bc-table">
                    <thead>
                        <tr>
                            <th class="col-nr">Nr.</th>
                            <th>Name</th>
                            <th>PLZ</th>
                            <th>Ort</th>
                            <th>Telefon</th>
                            <th>E-Mail</th>
                            <th class="col-num">Teilnehmer</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.Betriebe)
                        {
                            <tr class="bc-row-link @(b.Gesperrt ? "bc-row-gesperrt" : "")"
                                data-id="@b.BetriebId"
                                data-url="/Betriebe/Karte/@b.BetriebId"
                                data-nr="@b.BetriebNr"
                                data-name="@b.Name"
                                data-plz="@(b.PLZ ?? "–")"
                                data-ort="@(b.Ort ?? "–")"
                                data-telefon="@(b.Telefon ?? "–")"
                                data-email="@(b.Email ?? "–")"
                                data-tn="@b.AnzahlTeilnehmer">
                                <td class="col-nr"><a href="/Betriebe/Karte/@b.BetriebId" onclick="openModalWithNav(this.href);return false">@b.BetriebNr</a></td>
                                <td>
                                    @b.Name
                                    @if (b.Gesperrt) { <span class="bc-badge bc-badge-gesperrt" style="margin-left:4px">Gesperrt</span> }
                                </td>
                                <td>@(b.PLZ ?? "–")</td>
                                <td>@(b.Ort ?? "–")</td>
                                <td>@(b.Telefon ?? "–")</td>
                                <td>@(b.Email ?? "–")</td>
                                <td class="col-num">@b.AnzahlTeilnehmer</td>
                            </tr>
                        }
                        @if (!Model.Betriebe.Any())
                        {
                            <tr><td colspan="7" style="text-align:center;color:#a19f9d;padding:16px">Noch keine Betriebe vorhanden</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="bc-factbox" id="bc-factbox">
            <div class="bc-factbox-header">Details</div>
            <div class="bc-factbox-body" id="bc-factbox-body">
                <p class="bc-factbox-empty">Zeile auswählen…</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var table   = document.getElementById('bc-table');
    var fbBody  = document.getElementById('bc-factbox-body');
    var search  = document.getElementById('bc-search');
    var countEl = document.getElementById('entry-count');
    var btnBearb = document.getElementById('btn-bearbeiten');
    var allRows = table ? Array.from(table.querySelectorAll('tbody tr[data-id]')) : [];
    var sel     = null;

    function esc(s) { return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
    function frow(l, v) {
        return '<div class="bc-factbox-row"><span class="bc-factbox-label">' + l + '</span>'
             + '<span class="bc-factbox-value">' + esc(v) + '</span></div>';
    }

    function buildFactbox(d) {
        return '<div class="bc-factbox-title">' + esc(d.name) + '</div>'
             + '<div class="bc-factbox-nr">' + esc(d.nr) + '</div>'
             + frow('PLZ / Ort', d.plz + ' ' + d.ort)
             + frow('Telefon', d.telefon)
             + frow('E-Mail', d.email)
             + frow('Teilnehmer', d.tn)
             + '<button class="bc-factbox-open" onclick="openModalWithNav(\'' + esc(d.url) + '\')">Karte öffnen ↗</button>';
    }

    function openModalWithNav(url) {
        var vis = allRows.filter(function(r) { return !r.hidden; });
        var idx = vis.findIndex(function(r) { return r.dataset.url === url; });
        openModal(url, vis.map(function(r) { return r.dataset.url; }), idx);
    }

    allRows.forEach(function (tr) {
        tr.addEventListener('click', function () {
            if (sel) sel.classList.remove('bc-row-selected');
            tr.classList.add('bc-row-selected');
            sel = tr;
            if (fbBody) fbBody.innerHTML = buildFactbox(tr.dataset);
            if (btnBearb) {
                btnBearb.dataset.url = tr.dataset.url;
                btnBearb.classList.remove('disabled');
            }
        });
        tr.addEventListener('dblclick', function () { openModalWithNav(tr.dataset.url); });
    });

    if (search) {
        search.addEventListener('input', function () {
            var q = this.value.toLowerCase();
            allRows.forEach(function (tr) { tr.hidden = q.length > 0 && !tr.textContent.toLowerCase().includes(q); });
            updateCount();
        });
    }

    function updateCount() {
        var vis = allRows.filter(function (r) { return !r.hidden; }).length;
        if (countEl) countEl.textContent = vis === allRows.length
            ? allRows.length + ' Betriebe'
            : vis + ' von ' + allRows.length + ' Betrieben';
    }
    updateCount();
})();
</script>
}
